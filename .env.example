# ============================================================
# Environment configuration — copy to .env and fill in values
# ============================================================

# --- Application ---
APP_NAME=agenthub
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
# JSON array of allowed CORS origins (frontend URL)
CORS_ORIGINS=["http://localhost:3000"]

# --- Database (PostgreSQL + pgvector) ---
# NOTE: host port is 5433 (not 5432) to avoid clashing with a local Postgres.
POSTGRES_USER=aap
POSTGRES_PASSWORD=aap_secret
POSTGRES_DB=aap
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
# Full DSN used by SQLAlchemy (built from above by default)
DATABASE_URL=postgresql+psycopg://aap:aap_secret@localhost:5433/aap

# --- Logto (authentication) ---
# After first `docker-compose up`, open Logto admin console at http://localhost:3002
# Create a "Traditional Web" application, then fill these:
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_ISSUER=http://localhost:3001/oidc
LOGTO_AUDIENCE=http://localhost:8000/api
# Default admin user (bootstrapped on first run)
LOGTO_ADMIN_SUBJECT=admin-user

# --- Local password auth (bcrypt) ---
# Used to sign HS256 JWTs issued by POST /api/v1/auth/login. Change in production!
JWT_SECRET=change-me-in-production
SALT_ROUNDS=12
ACCESS_TOKEN_TTL_MINUTES=60
SESSION_TTL_HOURS=168

# Frontend URL (used for emails + default CORS)
APP_URL=http://localhost:3000

# --- pycasbin ---
CASBIN_MODEL_PATH=casbin_model.conf

# --- LLM (for LangGraph agent) ---
# DeepSeek is OpenAI-compatible: same ChatOpenAI client, just a different
# base_url + model. See https://api-docs.deepseek.com/
# These are the last-resort fallback when no DB-stored LLM config exists.
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
# Thinking-mode toggle for reasoning-capable models (deepseek-v4-flash, etc.).
# true  = let the provider default apply (thinking ON where supported)
# false = send extra_body={"thinking":{"type":"disabled"}} for faster/cheaper
#         non-reasoning responses. Ignored by models without a thinking mode.
LLM_THINKING_ENABLED=true

# --- Embedding model (priority 57 — knowledge base / RAG) ---
# DeepSeek has no embeddings endpoint, so embeddings target a provider that
# does (OpenAI by default). Same tenant > platform > env resolution as the
# chat LLM above.
EMBEDDING_API_KEY=sk-replace-me
EMBEDDING_BASE_URL=https://api.openai.com
EMBEDDING_MODEL=text-embedding-3-small

# --- Demo dataset seeding (db-revamp-and-scenario-rebuild plan) ---
# Real keys used ONLY by `scripts/seed_demo.py` to populate the platform-level
# LlmConfig/EmbeddingConfig so the demo can do live chat + real RAG on first
# boot. Leave empty to use the inert placeholder (chat/RAG configurable but
# not callable until a key is supplied). NEVER commit a real key — .env only
# (.env is gitignored).
DEMO_LLM_API_KEY=
DEMO_EMBEDDING_API_KEY=
# Demo login prefill (plan §4). Returned by GET /auth/login-hint ONLY when
# APP_ENV is development/testing; production always returns nulls.
DEMO_LOGIN_USERNAME=admin
DEMO_LOGIN_PASSWORD=Admin@123456

# --- Field-level encryption (for DB-stored secrets like LLM API keys) ---
# Fernet key (base64 urlsafe 32 bytes). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Dev/test uses a baked-in default; production MUST override this.
FIELD_ENCRYPTION_KEY=

# --- File upload / object storage (priority 56) ---
# Backend: local (default, writes to STORAGE_LOCAL_DIR + serves via GET /uploads/files)
#          s3   (real AmazonS3Storage, boto3 is a runtime dep)
#          oss  (stub — raises NotImplementedError until oss2 is wired in)
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=uploads
UPLOAD_MAX_BYTES=10485760
# S3 (only used when STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Aliyun OSS (only used when STORAGE_BACKEND=oss — currently a stub)
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
