# ============================================================
# Environment configuration — copy to .env and fill in values
# ============================================================

# --- Application ---
APP_NAME=ai-agent-platform
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
# JSON array of allowed CORS origins (frontend URL)
CORS_ORIGINS=["http://localhost:3000"]

# --- Database (PostgreSQL + pgvector) ---
# NOTE: host port is 5433 (not 5432) to avoid clashing with a local Postgres.
POSTGRES_USER=aap
POSTGRES_PASSWORD=aap_secret
POSTGRES_DB=aap
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
# Full DSN used by SQLAlchemy (built from above by default)
DATABASE_URL=postgresql+psycopg://aap:aap_secret@localhost:5433/aap

# --- Logto (authentication) ---
# After first `docker-compose up`, open Logto admin console at http://localhost:3002
# Create a "Traditional Web" application, then fill these:
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_ISSUER=http://localhost:3001/oidc
LOGTO_AUDIENCE=http://localhost:8000/api
# Default admin user (bootstrapped on first run)
LOGTO_ADMIN_SUBJECT=admin-user

# --- Local password auth (bcrypt) ---
# Used to sign HS256 JWTs issued by POST /api/v1/auth/login. Change in production!
JWT_SECRET=change-me-in-production
SALT_ROUNDS=12
ACCESS_TOKEN_TTL_MINUTES=60
SESSION_TTL_HOURS=168

# Frontend URL (used for emails + default CORS)
APP_URL=http://localhost:3000

# --- pycasbin ---
CASBIN_MODEL_PATH=casbin_model.conf

# --- LLM (for LangGraph agent) ---
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
